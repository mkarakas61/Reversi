rules_version = '2';

// Reversi online security rules (draft — tightened in REV-51).
//
// Core principle: clients may only write the "safe" identity fields of their
// own profile. Everything that affects ranking — xp, level and the online
// stats — is written exclusively by Cloud Functions via the Admin SDK, which
// bypasses these rules. So a player can never edit their own XP/level/stats.
service cloud.firestore {
  match /databases/{database}/documents {

    function signedIn() {
      return request.auth != null;
    }

    function isOwner(uid) {
      return signedIn() && request.auth.uid == uid;
    }

    match /users/{uid} {
      // Any signed-in user can read profiles — needed later to show an
      // opponent's basic stats before a match (REV-45).
      allow read: if signedIn();

      // Owner may create their profile with only identity fields.
      allow create: if isOwner(uid)
        && request.resource.data.keys().hasOnly(
             ['displayName', 'photoUrl', 'createdAt', 'updatedAt']);

      // Owner may update only identity fields. xp / level / online are owned by
      // Cloud Functions, so the client can never touch them.
      allow update: if isOwner(uid)
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(
             ['displayName', 'photoUrl', 'updatedAt']);

      allow delete: if false;
    }

    // Matchmaking tickets: a user only manages their own ticket. The actual
    // pairing is done by a Cloud Function (Admin SDK). Tightened in REV-43.
    match /matchmaking/{uid} {
      allow read, create, update, delete: if isOwner(uid);
    }

    // Games: only the two participants may read. The game doc is created by the
    // matchmaking function (Admin). During an active game either participant may
    // update it to record their move; the server validates the result and awards
    // XP by replaying the move log (REV-50), and REV-51 tightens this to
    // turn-and-field-level checks. Game docs carry a `playerUids` array.
    match /games/{gameId} {
      allow read: if signedIn()
        && request.auth.uid in resource.data.playerUids;
      allow update: if signedIn()
        && request.auth.uid in resource.data.playerUids
        && resource.data.status == 'active';
      allow create, delete: if false;
    }
  }
}
