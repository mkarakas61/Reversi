rules_version = '2';

// Reversi online security rules (tightened in REV-51).
//
// Core principle: clients may only write the "safe" identity fields of their
// own profile. Everything that affects ranking — xp, level and the online
// stats — is written exclusively by Cloud Functions via the Admin SDK, which
// bypasses these rules. So a player can never edit their own XP/level/stats.
service cloud.firestore {
  match /databases/{database}/documents {

    function signedIn() {
      return request.auth != null;
    }

    function isOwner(uid) {
      return signedIn() && request.auth.uid == uid;
    }

    match /users/{uid} {
      // Any signed-in user can read profiles.
      allow read: if signedIn();

      // Owner may create their profile with only identity fields.
      allow create: if isOwner(uid)
        && request.resource.data.keys().hasOnly(
             ['displayName', 'photoUrl', 'createdAt', 'updatedAt']);

      // Owner may update only identity fields. xp / level / online.* are
      // owned by Cloud Functions and can never be touched by the client.
      allow update: if isOwner(uid)
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(
             ['displayName', 'photoUrl', 'updatedAt']);

      allow delete: if false;
    }

    // Matchmaking tickets: a user only manages their own ticket. The actual
    // pairing is done by a Cloud Function (Admin SDK). Tightened in REV-43.
    match /matchmaking/{uid} {
      allow read, create, update, delete: if isOwner(uid);
    }

    // Returns true when the update touches any board-state field, i.e. it
    // is a move submission rather than a heartbeat, resign, or cancel.
    function isMoveWrite() {
      let changed = request.resource.data.diff(resource.data).affectedKeys();
      return changed.hasAny(['board', 'moves', 'moveCount', 'currentPlayer',
                             'lastMove', 'turnDeadline']);
    }

    // Returns true when it is the requesting player's turn.
    function isMyTurn() {
      return (resource.data.currentPlayer == 'black'
              && request.auth.uid == resource.data.players.black)
          || (resource.data.currentPlayer == 'white'
              && request.auth.uid == resource.data.players.white);
    }

    // Games: only the two participants may read. The game doc is created by
    // the matchmaking function (Admin SDK — bypasses these rules).
    // During an active game:
    //   - Any participant may do a non-board write (heartbeat, resign,
    //     claimDisconnectWin, cancel).
    //   - Board-changing writes (move submissions) are additionally
    //     restricted to the player whose turn it is (REV-51 anti-cheat).
    // Finished or cancelled games are read-only.
    match /games/{gameId} {
      allow read: if signedIn()
        && request.auth.uid in resource.data.playerUids;

      allow update: if signedIn()
        && request.auth.uid in resource.data.playerUids
        && resource.data.status == 'active'
        && (!isMoveWrite() || isMyTurn());

      allow create, delete: if false;
    }
  }
}
